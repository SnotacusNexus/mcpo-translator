# MCPO Translator Configuration

# Server Configuration
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# MCPO Server Configuration
MCPO_BASE_URL=https://mcpo.gophernuttz.us
MCPO_AUTH_TOKEN=your-bearer-token-here

# Cache Configuration
CACHE_ENABLED=true
CACHE_TTL=60000  # 1 minute in milliseconds
CACHE_MAX_SIZE=100

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000  # 1 minute
RATE_LIMIT_MAX=100  # requests per window

# Security
CORS_ORIGIN=http://localhost:3000
ALLOWED_METHODS=GET,POST,OPTIONS

# Performance
REQUEST_TIMEOUT=30000  # 30 seconds
CONNECTION_TIMEOUT=5000  # 5 seconds

# WebSocket
WEBSOCKET_MAX_PAYLOAD=1048576  # 1MB
WEBSOCKET_HEARTBEAT_INTERVAL=30000  # 30 seconds

# Notes:
# 1. Copy this file to .env and update values
# 2. MCPO_AUTH_TOKEN is required for authenticated endpoints
# 3. Set NODE_ENV=production for production